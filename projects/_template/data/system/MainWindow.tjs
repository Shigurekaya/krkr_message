        clearBgmStop();
        clearBgmLabel();
		return 0;
	} incontextof this,

	bgmopt : function(elm)
	{
		// 设置 BGM 选项
		bgm.setOptions(elm);
		return 0;
	} incontextof this,
    setbgmstop : function(elm)
	{
		// 注册 BGM 结束回调
        setBgmStop(elm);
        return 0;
	} incontextof this,

    clearbgmstop : function(elm)
	{
		// 删除 BGM 结束回调
        clearBgmStop();
        return 0;
	} incontextof this,

    setbgmlabel : function(elm) {
        // 注册 BGM 标签回调
        setBgmLabel(elm);
        return 0;
    } incontextof this,

    clearbgmlabel : function(elm)
	{
        // 删除 BGM 标签回调
        clearBgmLabel();
        return 0;
	} incontextof this,

	wb : function(elm)
	{
		// 等待 BGM 淡出结束
		return waitBGMFade(elm);
	} incontextof this,

	wl : function(elm)
	{
		// 等待 BGM 播放结束
		return waitBGMStop(elm);
	} incontextof this,

	playse : function(elm)
	{
		// 播放音效
		se[+elm.buf].play(elm);
