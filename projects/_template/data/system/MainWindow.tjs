	fadeinse : function(elm)
	{
		// 音效淡入播放
		se[+elm.buf].fadeIn(elm);
		return 0;
	} incontextof this,

	fadeoutse : function(elm)
	{
		// 音效淡出
		se[+elm.buf].fadeOut(elm);
		return 0;
	} incontextof this,

	fadese : function(elm)
	{
		// 音效淡入淡出
		se[+elm.buf].fade(elm);
		return 0;
	} incontextof this,

	seopt : function(elm)
	{
		// 设置音效选项
		se[+elm.buf].setOptions(elm);
		return 0;
	} incontextof this,

	wf : function(elm)
	{
		// 等待音效淡出结束
		return waitSEFade(elm);
	} incontextof this,

	ws : function(elm)
	{
		// 等待音效播放结束
		return waitSEStop(elm);
	} incontextof this,

	video : function(elm)
	{
		// 设置视频选项
		movies[+elm.slot].setOptions(elm);
		return 0;
	} incontextof this,

	playvideo : function(elm)
	{
		// 播放视频
		movies[+elm.slot].play(elm.storage);
		return 0;
	} incontextof this,

	stopvideo : function(elm)
	{
		// 停止视频
		movies[+elm.slot].stop();
		return 0;
