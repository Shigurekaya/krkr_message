			var dy = param.shadowy !== void ? +param.shadowy : 10;
			var blur = param.shadowblur !== void ? +param.shadowblur : 3;
			var color = param.shadow === true ? 0 : +param.shadow;
			var opacity = param.shadowopacity !== void ? +param.shadowopacity : 200;
