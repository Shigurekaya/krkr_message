	record : function(elm)
	{
		// 进行经过记录
		setToRecordHistory();
		return 0;
	} incontextof this,

	tempsave : function(elm)
	{
		// 将状态保存到内存
		tempSave(+elm.place);
		return 0;
	} incontextof this,

	tempload : function(elm)
	{
		// 从内存加载状态
		tempLoad(+elm.place, elm);
			//elm.se === void || +elm.se, elm.bgm === void || +elm.bgm,
			//elm.backlay !== void && +elm.backlay);
		return 0;
	} incontextof this,

	mappfont : function(elm)
	{
		// 将预渲染字体映射到当前字体
		mapPrerenderedFont(elm.storage);
		return 0;
	} incontextof this,

	locksnapshot : function(elm)
	{
		// 锁定画面快照
		lockSnapshot();
		return 0;
	} incontextof this,

	unlocksnapshot : function(elm)
	{
		// 解除画面快照锁定
		unlockSnapshot();
		return 0;
	} incontextof this,

	//------------------------------------------- 标签处理函数群（层操作） --

	image : function(elm)
	{
		// 图像读取
		updateBeforeCh = 1;
		var start = System.getTickCount();
		getLayerFromElm(elm).loadImages(elm);
		dm(elm.storage + " 加载耗时 " + (System.getTickCount() - start) + "ms");
		return 0;
	} incontextof this,

	img : function(elm)
	{
		// 图像读取（同 image）
		updateBeforeCh = 1;
		var start = System.getTickCount();
		getLayerFromElm(elm).loadImages(elm);
		dm(elm.storage + " 加载耗时 " + (System.getTickCount() - start) + "ms");
		return 0;
	} incontextof this,

	pimage : function(elm)
	{
		// 部分追加图像读取
		getLayerFromElm(elm).loadPartialImage(elm);
		return 0;
	} incontextof this,

	ptext : function(elm)
	{
		// 向背景/立绘层绘制文字
		getLayerFromElm(elm).drawReconstructibleText(elm);
		return 0;
	} incontextof this,

	freeimage : function(elm)
	{
		// 清除图像
		updateBeforeCh = 1;
		getLayerFromElm(elm).freeImage(elm);
		return 0;
	} incontextof this,

	animstart : function(elm)
	{
		// 开始动画
		updateBeforeCh = 1;
		getLayerFromElm(elm).startAnim(elm);
		return 0;
	} incontextof this,

	animstop : function(elm)
	{
		// 停止动画
		updateBeforeCh = 1;
		getLayerFromElm(elm).stopAnim(+elm.seg);
		return 0;
	} incontextof this,

	wa : function(elm)
	{
		// 等待动画停止
		return waitAnimation(elm);
	} incontextof this,

	mapimage : function(elm)
	{
		// 读取可点击地图的区域图
		getLayerFromElm(elm).loadProvinceImage(elm.storage);
		return 0;
	} incontextof this,

	mapaction : function(elm)
	{
		// 读取可点击地图的区域动作定义
		getLayerFromElm(elm).loadProvinceActions(elm.storage);
		return 0;
	} incontextof this,

	mapdisable : function(elm)
	{
		// 禁用可点击地图
		getLayerFromElm(elm).clearProvinceActions();
		return 0;
	} incontextof this,

	backlay : function(elm)
	{
		// 将层复制到里屏
		updateBeforeCh = 1;
		backupLayer(elm, true);
		return 0;
	} incontextof this,

	forelay : function(elm)
	{
		// 将层复制到表屏
		updateBeforeCh = 1;
		backupLayer(elm, false);
		return 0;
	} incontextof this,

	copylay : function(elm)
	{
		// 同类型层之间的复制
		updateBeforeCh = 1;
		copyLayer(elm);
		return 0;
	} incontextof this,

	layopt : function(elm)
	{
		// 设置层选项
		updateBeforeCh = 1;
		getLayerFromElm(elm).setOptions(elm);
		return 0;
	} incontextof this,

	trans : function(elm)
	{
		// 开始过渡
		getLayerPageFromElm(elm, false).beginTransition(elm);
		return 0;
	} incontextof this,

	wt : function(elm)
	{
		// 等待过渡
		return waitTransition(elm);
	} incontextof this,

	stoptrans : function(elm)
	{
		// 停止过渡
		stopAllTransitions();
		return 0;
	} incontextof this,

	move : function(elm)
	{
		// 开始自动移动
		getLayerFromElm(elm).beginMove(elm);
		return 0;
	} incontextof this,

	// layer, page, fps, ox, oy
	framemove : function(elm)
	{
		// 开始按帧指定自动移动
		getLayerFromElm(elm).beginFrameMove(elm);
		return 0;
	} incontextof this,

	wm : function(elm)
	{
		// 等待自动移动
		return waitMove(elm);
	} incontextof this,

	stopmove : function(elm)
	{
		// 停止自动移动
		stopAllMoves();
		return 0;
	} incontextof this,

	laycount : function(elm)
	{
		updateBeforeCh = 1;
		allocateCharacterLayers(+elm.layers) if elm.layers !== void;
		allocateMessageLayers(+elm.messages) if elm.messages !== void;
		return 0;
	} incontextof this,

	//------------------------------ 标签处理函数群（音效·BGM·视频操作） --

	playbgm : function(elm)
	{
		// 播放 BGM
		bgm.play(elm);
        clearBgmStop();
        clearBgmLabel();
		return 0;
	} incontextof this,

	stopbgm : function(elm)
	{
		// 停止 BGM
		bgm.stop();
		return 0;
	} incontextof this,

	pausebgm : function(elm)
	{
		// 暂停 BGM
		bgm.pause();
		return 0;
	} incontextof this,

	resumebgm : function(elm)
	{
		// 恢复 BGM
		bgm.resume();
		return 0;
	} incontextof this,

	fadeinbgm : function(elm)
	{
		// BGM 淡入
		bgm.fadeIn(elm);
		return 0;
	} incontextof this,

	fadeoutbgm : function(elm)
	{
		// BGM 淡出
		bgm.fadeOut(elm);
		return 0;
	} incontextof this,

	fadepausebgm : function(elm)
	{
		// BGM 淡出暂停
		bgm.fadePause(elm);
		return 0;
	} incontextof this,

	fadebgm : function(elm)
	{
		// BGM 淡入到指定音量
		bgm.fade(elm);
		return 0;
	} incontextof this,

	xchgbgm : function(elm)
	{
		// BGM 切换/交叉淡入淡出
